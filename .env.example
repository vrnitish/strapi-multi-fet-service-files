# Strapi
STRAPI_URL=http://localhost:1337
STRAPI_TOKEN=your-strapi-api-token-here
STRAPI_TIMEOUT=10000

# Populate depth for Strapi API calls (default: 4)
P_LEVEL=4

# Schema field names
COMPONENT_COLLECTION=component-instances
COMPONENT_ZONE_FIELD=components
COMPONENT_TYPE_FIELD=__component
ENTITY_LABEL_FIELD=component_title
LOCALIZATION_FIELD=localizations

# Collection keys — field_name:collection-api-name (comma-separated)
# Maps relation field names in responses to their Strapi collection plural API names
COLLECTION_KEYS=component_instance:component-instances,component_instances:component-instances,user_types:user-types

# Redis Cache
CACHE_ENABLED=true
REDIS_URL=redis://localhost:6379
CACHE_TTL=300
CACHE_KEY_FIELD=slug

# Security
WEBHOOK_SECRET=your-webhook-secret-here

# Server
PORT=3001
